## 51) Metering: Peak / RMS / LIM_GR / CLIP (параллельно pipeline)

```c
typedef struct {
    float   peak_L, peak_R;       // peak hold (decay медленный)
    float   rms_L,  rms_R;        // RMS IIR (окно ~300 ms)
    float   lim_gr_db;            // from LookAheadLimiter.gr_db
    uint32_t clip_count;          // from LookAheadLimiter.clip_count
    uint8_t  clip_active;         // мгновенный флаг (сброс через 300ms)
} Meters;

void meters_update(Meters *m, float *L, float *R, int n, float fs,
                   LookAheadLimiter *lim) {
    float alpha_rms  = 1.0f - expf(-(float)n / (fs * 0.300f));
    float alpha_peak = 1.0f - expf(-(float)n / (fs * 1.500f)); // медл. спад

    for (int i = 0; i < n; i++) {
        float aL = fabsf(L[i]), aR = fabsf(R[i]);
        // Peak hold:
        if (aL > m->peak_L) m->peak_L = aL;
        else                m->peak_L -= m->peak_L * alpha_peak;
        if (aR > m->peak_R) m->peak_R = aR;
        else                m->peak_R -= m->peak_R * alpha_peak;
        // RMS:
        m->rms_L += (aL*aL - m->rms_L) * alpha_rms;
        m->rms_R += (aR*aR - m->rms_R) * alpha_rms;
    }
    m->lim_gr_db  = lim->gr_db;
    m->clip_count = lim->clip_count;
    m->clip_active = (lim->gr_db < -0.5f) ? 1 : 0;
}
```

