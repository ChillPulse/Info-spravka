```c
// В DMA half/full callback:
static volatile uint8_t dsp_ready = 0;

void dma_half_callback(void) {
    if (dsp_ready) {
        prof.overrun_count++;
        // Лог: ERR:0x0303:DMA_HALF_MISS
    }
    dsp_ready = 1;
    // Сигналить task через semaphore/notification
}
