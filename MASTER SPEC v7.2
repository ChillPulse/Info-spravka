## 50) Bass Mono + Psychobass

### 50.1 Bass Mono

```c
typedef struct {
    uint8_t enable;
    float   fc;       // частота разделения (Hz)
    float   mix;      // 0..1 (1 = полное моно ниже fc)
    Biquad  lpf_L, lpf_R, lpf_sum;
    Biquad  hpf_L, hpf_R;
} BassMono;

void bassmono_process(BassMono *bm, float *L, float *R, int n) {
    if (!bm->enable) return;
    for (int i = 0; i < n; i++) {
        float bass_L = biquad_process(&bm->lpf_L, L[i]);
        float bass_R = biquad_process(&bm->lpf_R, R[i]);
        float bass_M = (bass_L + bass_R) * 0.5f;
        float hi_L   = biquad_process(&bm->hpf_L, L[i]);
        float hi_R   = biquad_process(&bm->hpf_R, R[i]);
        // Crossfade bass_mono/stereo по bm->mix:
        L[i] = hi_L + bass_L * (1.0f - bm->mix) + bass_M * bm->mix;
        R[i] = hi_R + bass_R * (1.0f - bm->mix) + bass_M * bm->mix;
    }
}

// Toggle команда — через dry/wet GainSmoother (без щелчка):
// BASSMONO:TOGGLE → crossfade mix: 0→1 или 1→0 за TAU_VOL_MS
```

### 50.2 Psychobass (subharmonic synthesizer)

```c
typedef struct {
    uint8_t enable;
    float   fc;       // граничная частота (Hz)
    float   depth;    // 0..1
    Biquad  lpf;      // выделяем НЧ
    Biquad  hpf_out;  // фильтр выходной субгармоники
    float   phase;    // для полуволнового выпрямителя
} Psychobass;

void psychobass_process(Psychobass *pb, float *L, float *R, int n) {
    if (!pb->enable) return;
    for (int i = 0; i < n; i++) {
        float mono = (L[i] + R[i]) * 0.5f;
        float low  = biquad_process(&pb->lpf, mono);
        // Полуволновое выпрямление → октава вниз:
        float sub  = (low > 0.0f) ? low : 0.0f;
        sub = biquad_process(&pb->hpf_out, sub);
        L[i] += sub * pb->depth;
        R[i] += sub * pb->depth;
    }
}
```

