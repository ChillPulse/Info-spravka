## 47) Night Mode Compressor + Bass Tame

### 47.1 Night Mode: wideband downward compressor

**Цель:** ночью диалоги слышны, пики не будят.

```c
typedef struct {
    uint8_t enable;
    float   threshold_db;   // -24..-18 dBFS
    float   ratio;          // 2.0..4.0
    float   attack_ms;      // 10–30 ms
    float   release_ms;     // 100–400 ms
    float   makeup_db;      // 0..+3 dB
} Night_Params;

typedef struct {
    Night_Params p;
    float  env;            // envelope follower
    float  gain_current;
    GainSmoother gs;
} NightComp;

void night_process_block(NightComp *nc, float *L, float *R,
                         int n, float fs) {
    if (!nc->p.enable) return;

    float thr_lin = powf(10.0f, nc->p.threshold_db / 20.0f);
    float makeup  = powf(10.0f, nc->p.makeup_db / 20.0f);

    for (int i = 0; i < n; i++) {
        // Peak envelope follower:
        float peak = fmaxf(fabsf(L[i]), fabsf(R[i]));
        float a = (peak > nc->env)
            ? gain_smoother_alpha_fs(nc->p.attack_ms, fs, 1)
            : gain_smoother_alpha_fs(nc->p.release_ms, fs, 1);
        nc->env += (peak - nc->env) * a;

        // Gain computer:
        float g = 1.0f;
        if (nc->env > thr_lin) {
            float over = nc->env / thr_lin;
            g = powf(over, 1.0f / nc->p.ratio - 1.0f);
        }
        g *= makeup;

        // Smooth:
        nc->gain_current += (g - nc->gain_current)
            * gain_smoother_alpha_fs(nc->p.attack_ms, fs, 1);

        L[i] *= nc->gain_current;
        R[i] *= nc->gain_current;
    }
}
```

### 47.2 Bass Tame: dynamic low-shelf

**Цель:** прижать басовые всплески, не убивая всё.

```c
typedef struct {
    uint8_t enable;
    float   fc;           // 80..150 Hz
    float   max_cut_db;   // -3..-9 dB
    float   attack_ms;    // 20–80 ms
    float   release_ms;   // 200–800 ms
} BassTame_Params;

typedef struct {
    BassTame_Params p;
    Biquad  lpf;       // детектор: LPF чтобы измерить энергию низа
    Biquad  shelf;     // управляемый low-shelf
    float   env;
    float   shelf_gain_current_db;
    GainSmoother gs_shelf;
} BassTame;

void basstame_process_block(BassTame *bt, float *L, float *R,
                            int n, float fs) {
    if (!bt->p.enable) return;

    for (int i = 0; i < n; i++) {
        // Sidechain: энергия НЧ (через LPF):
        float mono_bass = biquad_process(&bt->lpf,
                                         (L[i] + R[i]) * 0.5f);
        float energy = mono_bass * mono_bass;

        // Envelope:
        float a = (energy > bt->env)
            ? gain_smoother_alpha_fs(bt->p.attack_ms, fs, 1)
            : gain_smoother_alpha_fs(bt->p.release_ms, fs, 1);
        bt->env += (energy - bt->env) * a;

        // Target shelf gain (чем больше бас-энергия, тем больше cut):
        float level_db = 10.0f * log10f(bt->env + 1e-9f);
        float cut_db   = 0.0f;
        if (level_db > -12.0f) {
            // Плавная функция cut:
            float over = (level_db + 12.0f) / 12.0f;  // 0..1
            cut_db = bt->p.max_cut_db * fminf(over, 1.0f);
        }

        // Применить через управляемый shelf:
        bt->shelf_gain_current_db += (cut_db - bt->shelf_gain_current_db)
            * gain_smoother_alpha_fs(bt->p.attack_ms, fs, 1);
        biquad_ls(&bt->shelf, fs, bt->p.fc,
                  bt->shelf_gain_current_db, 0.707f);
        L[i] = biquad_process(&bt->shelf, L[i]);
        R[i] = biquad_process(&bt->shelf, R[i]);
    }
}
```

