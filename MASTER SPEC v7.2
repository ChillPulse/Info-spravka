### 53.3 RAM / Stack watermark

```c
// Stack watermark (заливка паттерном при старте):
#define STACK_CANARY  0xDEADBEEF

void stack_fill_canary(uint32_t *stack_base, uint32_t size) {
    for (uint32_t i = 0; i < size/4; i++)
        stack_base[i] = STACK_CANARY;
}

uint32_t stack_high_water(uint32_t *stack_base, uint32_t size) {
    uint32_t unused = 0;
    for (uint32_t i = 0; i < size/4; i++) {
        if (stack_base[i] == STACK_CANARY) unused++;
        else break;
    }
    return (size/4 - unused) * 4;  // байт использовано
}
```

