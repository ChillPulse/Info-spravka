    STATE_RADIO_MUTE,     // Radio mute (RADIO_MUTE=HIGH, смена Fs)
    STATE_BT_INIT,        // запуск BT домена (MCLK detect)
    STATE_BT_PLAY,        // воспроизведение BT (DSP active)
