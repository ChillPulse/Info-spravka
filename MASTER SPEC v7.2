## 53) v·core Performance Profiler (DWT + RAM/Stack + Counters)

### 53.1 DWT CPU profiler

```c
// Включить DWT при старте:
void profiler_init(void) {
    CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;
    DWT->CYCCNT       = 0;
    DWT->CTRL        |= DWT_CTRL_CYCCNTENA_Msk;
}

typedef struct {
    uint32_t cycles_last;    // циклы последнего process_block
    uint32_t cycles_avg;     // скользящее среднее
    uint32_t cycles_max;     // максимум за сессию
    float    cpu_load;       // 0.0..1.0
    uint32_t overrun_count;  // пропущенных half/full событий DMA
} DSP_Profiler;

// В process_block():
uint32_t t0 = DWT->CYCCNT;
// ... весь DSP ...
uint32_t t1 = DWT->CYCCNT;
uint32_t cy = t1 - t0;
prof.cycles_last = cy;
prof.cycles_max  = (cy > prof.cycles_max) ? cy : prof.cycles_max;
// EMA:
prof.cycles_avg  = (prof.cycles_avg * 7 + cy) / 8;
// Load (AT32F435 @ 288 МГц, block_size=128):
float budget = (float)BLOCK_SIZE / fs * 288e6f;
prof.cpu_load = (float)prof.cycles_avg / budget;
```

