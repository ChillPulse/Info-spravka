## 44) Mute Subsystem + Gain Smoother ("Премиальная плавность")

### 44.1 Mute Subsystem

```c
// Две независимые причины mute:
typedef struct {
    uint8_t mute_user;    // от пользователя (кнопка/IR MUTE)
    uint8_t mute_system;  // от системы (SRC switch, ошибка, standby)
    // итоговый mute: любой из двух → молчание
} MuteState;

// Приоритеты:
// mute_system имеет приоритет над mute_user в плане снятия:
// если mute_system=1, снятие mute_user ничего не даёт на выходе
// пока mute_system не будет снят системой

uint8_t mute_is_active(MuteState *ms) {
    return ms->mute_user || ms->mute_system;
}
```

**Команды протокола:**
- `MUTE` → `mute_user = 1`
- `UNMUTE` → `mute_user = 0`
- `MUTE:TOGGLE` → переключить `mute_user`

### 44.2 Gain Smoother: 1-pole IIR

```c
// Константы времени (мс → коэффициент alpha при заданном Fs и block_size):
// alpha = 1 - exp(-block_size / (fs * tau_sec))

#define TAU_VOL_MS       80.0f    // регулировка громкости
#define TAU_MUTE_IN_MS  200.0f    // затухание при mute
#define TAU_MUTE_OUT_MS 350.0f    // нарастание при unmute
#define TAU_SRC_MS       20.0f    // переключение источника

typedef struct {
    float current;     // текущий gain (линейный)
    float target;      // целевой gain (линейный)
    float alpha;       // коэффициент сглаживания (per-block)
} GainSmoother;

void gain_smoother_init(GainSmoother *gs, float fs, float block_size,
                        float tau_ms) {
    gs->current = gs->target = 1.0f;
    gs->alpha   = 1.0f - expf(-(block_size / (fs * tau_ms * 0.001f)));
}

// Вызывать один раз на блок:
float gain_smoother_tick(GainSmoother *gs) {
    gs->current += (gs->target - gs->current) * gs->alpha;
    return gs->current;
}

// Применение к блоку:
void gain_smoother_apply(GainSmoother *gs, float *L, float *R, int n) {
    for (int i = 0; i < n; i++) {
        float g  = gs->current + (gs->target - gs->current)
                   * gs->alpha;   // per-sample рампа
        gs->current = g;
        L[i] *= g;
        R[i] *= g;
    }
}
```

**Gain Smoother применяется к:**
- Master Volume (энкодер/IR).
- Mute/Unmute.
- Source trim / headroom offsets.
- Включение/выключение эффектов, меняющих амплитуду.
- Dry/wet crossfade (AETHER, Night, Anti-Ad).
- Любые "enable" переключения в DSP.

### 44.3 Master Volume

```c
// Хранение: dB × 10 (int16), диапазон -800..0 (-80.0..0.0 dB)
// Шаг: 5 (= 0.5 dB)

float db_to_linear(float db) {
    return powf(10.0f, db / 20.0f);
}

// При получении VOL:NNN от UI:
void vol_set(int16_t db10) {
    float db     = db10 / 10.0f;
    float linear = db_to_linear(db + auto_preamp_db);
    // Установить target Gain Smoother (с TAU_VOL):
    gs_vol.target = mute_is_active(&mute) ? 0.0f : linear;
    gs_vol.alpha  = gain_smoother_alpha(TAU_VOL_MS);
    // Уведомить UI:
    uart_ui_send("GAIN:%d\r\n", db10);
}

// При MUTE:
void mute_engage(MuteState *ms, uint8_t is_user) {
    if (is_user) ms->mute_user = 1;
    else         ms->mute_system = 1;
    gs_vol.target = 0.0f;
    gs_vol.alpha  = gain_smoother_alpha(TAU_MUTE_IN_MS);
}

// При UNMUTE:
void mute_release(MuteState *ms, uint8_t is_user) {
    if (is_user) ms->mute_user = 0;
    else         ms->mute_system = 0;
    if (!mute_is_active(ms)) {
        gs_vol.target = db_to_linear(current_vol_db + auto_preamp_db);
        gs_vol.alpha  = gain_smoother_alpha(TAU_MUTE_OUT_MS);
    }
}
```

