    STATE_SWITCHING,      // переключение доменов RADIO↔BT
    STATE_MUTE_USER,      // mute_user=1 (плавный fade-out)
    STATE_STANDBY,        // standby (DSP остановлен, часы работают)
    STATE_ERROR,          // критическая ошибка
} VCore_State;

