## 46) Anti-Ad Leveling (downward-only Auto-Volume)

### 46.1 Назначение
Фильм тихий → реклама "стена звука". Блок быстро приглушает всплески средней громкости, медленно возвращает.

### 46.2 Параметры

```c
typedef struct {
    uint8_t  enable;
    float    threshold_db;    // +4..+6 dB относительно baseline
    float    attack_ms;       // 50–150 ms
    float    release_ms;      // 3000–10000 ms
    float    hold_ms;         // 500–2000 ms
    float    max_att_db;      // -12..-18 dB
    // max_boost_db = 0.0f ВСЕГДА (downward-only!)
} AntiAd_Params;
```

### 46.3 Реализация

```c
typedef struct {
    AntiAd_Params p;
    float  rms_short;      // short-term RMS (3s window, упрощённо: IIR)
    float  rms_baseline;   // long-term baseline (20–60s, с гейтингом тишины)
    float  gain_target;    // линейный gain (0.0..1.0)
    float  gain_current;   // через Gain Smoother
    float  hold_timer;     // таймер hold
    GainSmoother gs;
} AntiAd;

void antiad_process_block(AntiAd *aa, float *L, float *R, int n, float fs) {
    if (!aa->p.enable) return;

    // Вычислить RMS блока:
    float block_rms = 0.0f;
    for (int i = 0; i < n; i++)
        block_rms += (L[i]*L[i] + R[i]*R[i]) * 0.5f;
    block_rms = sqrtf(block_rms / n);

    // IIR обновление short/long RMS:
    float alpha_short = 1.0f - expf(-(float)n / (fs * 3.0f));
    float alpha_long  = 1.0f - expf(-(float)n / (fs * 40.0f));
    // Gating тишины для baseline (не обновляем если очень тихо):
    if (block_rms > 0.001f)  // -60 dBFS gate
        aa->rms_baseline += (block_rms - aa->rms_baseline) * alpha_long;
    aa->rms_short += (block_rms - aa->rms_short) * alpha_short;

    // Вычислить требуемый gain:
    float thr_lin = aa->rms_baseline
                  * powf(10.0f, aa->p.threshold_db / 20.0f);
    float max_att = powf(10.0f, aa->p.max_att_db / 20.0f);

    if (aa->rms_short > thr_lin) {
        // Нужно ослабить:
        float ratio  = aa->rms_short / thr_lin;
        float needed = 1.0f / ratio;
        aa->gain_target = fmaxf(needed, max_att);
        aa->hold_timer  = aa->p.hold_ms;
        aa->gs.alpha    = gain_smoother_alpha_fs(aa->p.attack_ms, fs, n);
    } else if (aa->hold_timer > 0) {
        aa->hold_timer -= (float)n / fs * 1000.0f;
    } else {
        // Медленное восстановление:
        aa->gain_target = 1.0f;
        aa->gs.alpha    = gain_smoother_alpha_fs(aa->p.release_ms, fs, n);
    }

    // Применить через smoother:
    float g = gain_smoother_tick(&aa->gs);
    for (int i = 0; i < n; i++) {
        L[i] *= g;
        R[i] *= g;
    }
}
```

