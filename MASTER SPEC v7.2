## 43) Базовые блоки DSP (DC, Subsonic, PEQ, Tone, Loudness)

### 43.1 DC Blocker

```c
// 1-pole high-pass, fc ≈ 0.5 Hz при любом Fs
// Коэффициент: R = 1 - (2*pi*fc/Fs)
typedef struct { float x1, y1; float R; } DCBlocker;

void dc_blocker_init(DCBlocker *dc, float fs) {
    dc->R  = 1.0f - (6.2832f * 0.5f / fs);
    dc->x1 = dc->y1 = 0.0f;
}
float dc_blocker_process(DCBlocker *dc, float x) {
    float y = x - dc->x1 + dc->R * dc->y1;
    dc->x1 = x; dc->y1 = y;
    return y;
}
// Применять к обоим каналам, всегда ON
```

### 43.2 Biquad DF2T (Direct Form II Transposed) — основа PEQ/Tone/Subsonic

```c
typedef struct {
    float b0, b1, b2;   // числитель
    float a1, a2;       // знаменатель (a0=1 нормализован)
    float s1, s2;       // состояние (transposed)
} Biquad;

float biquad_process(Biquad *bq, float x) {
    float y  = bq->b0 * x + bq->s1;
    bq->s1   = bq->b1 * x - bq->a1 * y + bq->s2;
    bq->s2   = bq->b2 * x - bq->a2 * y;
    return y;
}

// Коэффициенты PEQ (параметрический):
void biquad_peq(Biquad *bq, float fs, float fc, float gain_db, float Q) {
    float A  = powf(10.0f, gain_db / 40.0f);
    float w0 = 6.2832f * fc / fs;
    float alpha = sinf(w0) / (2.0f * Q);
    bq->b0 = 1.0f + alpha * A;
    bq->b1 = -2.0f * cosf(w0);
    bq->b2 = 1.0f - alpha * A;
    float a0 = 1.0f + alpha / A;
    bq->a1 = bq->b1 / a0;
    bq->a2 = (1.0f - alpha / A) / a0;
    bq->b0 /= a0; bq->b1 /= a0; bq->b2 /= a0;
    bq->s1 = bq->s2 = 0.0f;
}

// Low-shelf:
void biquad_ls(Biquad *bq, float fs, float fc, float gain_db, float Q) {
    float A  = powf(10.0f, gain_db / 40.0f);
    float w0 = 6.2832f * fc / fs;
    float cosw = cosf(w0), sinw = sinf(w0);
    float alpha = sinw / (2.0f * Q);
    float a0 = (A+1) + (A-1)*cosw + 2*sqrtf(A)*alpha;
    bq->b0 = (A*((A+1) - (A-1)*cosw + 2*sqrtf(A)*alpha)) / a0;
    bq->b1 = (2*A*((A-1) - (A+1)*cosw)) / a0;
    bq->b2 = (A*((A+1) - (A-1)*cosw - 2*sqrtf(A)*alpha)) / a0;
    bq->a1 = (-2*((A-1) + (A+1)*cosw)) / a0;
    bq->a2 = ((A+1) + (A-1)*cosw - 2*sqrtf(A)*alpha) / a0;
    bq->s1 = bq->s2 = 0.0f;
}
// High-shelf аналогично (знаки cosw инвертированы)
```

### 43.3 PEQ: 20 полос cascade

```c
#define PEQ_BANDS 20

typedef struct {
    Biquad   bq[PEQ_BANDS];
    uint8_t  enabled[PEQ_BANDS];
    float    fs;
} PEQ;

void peq_process_block(PEQ *peq, float *L, float *R, int n) {
    for (int s = 0; s < n; s++) {
        float l = L[s], r = R[s];
        for (int b = 0; b < PEQ_BANDS; b++) {
            if (!peq->enabled[b]) continue;
            l = biquad_process(&peq->bq[b], l);
            // Если стерео PEQ: отдельный biquad для R
            // Если моно-PEQ (одинаковый на оба): тот же biquad дважды
            // По умолчанию — одинаковые коэффициенты L/R:
            r = biquad_process(&peq->bq[b], r);
        }
        L[s] = l; R[s] = r;
    }
}
```

### 43.4 Headroom Manager

```c
// При изменении PEQ/Tone/Loudness пересчитываем auto_preamp:
// 1. Измерить суммарный boost на частоте максимального подъёма
// 2. auto_preamp = -max_boost (компенсация)
// 3. Применять через Gain Smoother

#define AMP_HEADROOM_DB  1.0f   // оставлять минимальный запас

float headroom_compute_preamp(PEQ *peq, Tone *tone) {
    float max_boost = 0.0f;
    // Сканируем gains всех полос:
    for (int b = 0; b < PEQ_BANDS; b++) {
        if (!peq->enabled[b]) continue;
        float g = peq->gains_db[b];
        if (g > max_boost) max_boost = g;
    }
    // Учитываем Tone:
    if (tone->bass_db > max_boost)   max_boost = tone->bass_db;
    if (tone->treble_db > max_boost) max_boost = tone->treble_db;
    // Компенсация:
    return -(max_boost + AMP_HEADROOM_DB);
}
```

