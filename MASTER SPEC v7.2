## 58) Supervisor / Watchdog (AT32 v·core)

### 58.1 Hardware Watchdog

```c
// AT32F435 IWDG:
// Период: ~2 сек
// В нормальной работе: feed watchdog в конце каждого DSP блока
// Если process_block() завис → watchdog reset → reboot → лог в crash log

void supervisor_feed_watchdog(void) {
    IWDG->KR = 0xAAAA;  // refresh
}

// В process_block() в конце:
supervisor_feed_watchdog();
```

### 58.2 Software Supervisor

```c
typedef struct {
    uint32_t last_dsp_tick;     // время последнего DSP блока
    uint32_t last_ui_ping;      // время последнего пинга от UI
    uint32_t last_yr_activity;  // время последней активности yoRadio
    uint8_t  ui_timeout_warned;
} Supervisor;

void supervisor_tick(Supervisor *sv, uint32_t now_ms) {
    // DSP overrun:
    if ((now_ms - sv->last_dsp_tick) > 500) {
        // DSP завис на 500ms → попытаться перезапустить I2S DMA
        i2s_restart();
        uart_log("ERR:0x0203:I2S3_DMA_STALL\r\n");
    }

    // UI timeout:
    if ((now_ms - sv->last_ui_ping) > 5000) {
        if (!sv->ui_timeout_warned) {
            uart_ui_send("ERR:0x0801:UILINK_TIMEOUT\r\n");
            sv->ui_timeout_warned = 1;
        }
    } else {
        sv->ui_timeout_warned = 0;
    }

    // yoRadio timeout (в RADIO режиме):
    if (state == STATE_RADIO_PLAY &&
        (now_ms - sv->last_yr_activity) > 10000) {
        uart_log("ERR:0x0402:UART_YR_FAIL\r\n");
    }
}
```

### 58.3 Crash Log

```c
// При watchdog reset или критической ошибке:
// Сохранить в последние N байт Flash (не в NVS — NVS может быть повреждён):

typedef struct {
    uint32_t timestamp_ms;
    uint32_t reset_reason;     // IWDG / Software / Power-on
    uint32_t pc_at_crash;      // program counter (из fault handler)
    uint32_t lr_at_crash;
    RT_Counters counters;      // все счётчики на момент краша
    DSP_Profiler profiler;     // CPU load и т.п.
    char     description[64];
} CrashEntry;

#define CRASH_LOG_ENTRIES  10
// Хранится в специальном Flash-регионе (не перезаписываемом при OTA)
// При старте — отправить в UI: EVT:crash log N entries
```

