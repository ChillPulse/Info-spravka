        int16_t s = rx_buf[offset_words + i];
        tx_buf[offset_words + i] = s;

        int32_t a = (s < 0) ? -s : s;
        uint32_t ua = (uint32_t)a;

        if (ua > peak_in) peak_in = ua;
        if (ua > peak_out) peak_out = ua;
