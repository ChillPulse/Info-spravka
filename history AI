static void process_audio_half(uint32_t offset_words)
{
    uint32_t peak_in = stats.peak_in_abs;
    uint32_t peak_out = stats.peak_out_abs;
    uint32_t clips = stats.clip_count;

    switch (proc_mode)
    {
        case 0:
            // raw copy
            for (uint32_t i = 0; i < HALF_WORDS; i++) {
                int16_t s = rx_buf[offset_words + i];
                tx_buf[offset_words + i] = s;

                int32_t a = (s < 0) ? -s : s;
                uint32_t ua = (uint32_t)a;
                if (ua > peak_in) peak_in = ua;
                if (ua > peak_out) peak_out = ua;
            }
            break;

        case 1:
            // identity
            for (uint32_t i = 0; i < HALF_WORDS; i++) {
                int16_t s = rx_buf[offset_words + i];

                int32_t ain = (s < 0) ? -s : s;
                if ((uint32_t)ain > peak_in) peak_in = (uint32_t)ain;

                int16_t y = s;

                tx_buf[offset_words + i] = y;

                int32_t aout = (y < 0) ? -y : y;
                if ((uint32_t)aout > peak_out) peak_out = (uint32_t)aout;
            }
            break;

        case 2:
            // signed divide by 2
            for (uint32_t i = 0; i < HALF_WORDS; i++) {
                int16_t s = rx_buf[offset_words + i];

                int32_t ain = (s < 0) ? -s : s;
                if ((uint32_t)ain > peak_in) peak_in = (uint32_t)ain;

                int16_t y = (int16_t)(s / 2);

                tx_buf[offset_words + i] = y;

                int32_t aout = (y < 0) ? -y : y;
                if ((uint32_t)aout > peak_out) peak_out = (uint32_t)aout;
            }
            break;

        case 3:
            // signed invert
            for (uint32_t i = 0; i < HALF_WORDS; i++) {
                int16_t s = rx_buf[offset_words + i];

                int32_t ain = (s < 0) ? -s : s;
                if ((uint32_t)ain > peak_in) peak_in = (uint32_t)ain;

                int16_t y;
                if (s == (int16_t)0x8000) {
                    y = 32767; // avoid overflow on -(-32768)
                    clips++;
                } else {
                    y = (int16_t)(-s);
                }

                tx_buf[offset_words + i] = y;

                int32_t aout = (y < 0) ? -y : y;
                if ((uint32_t)aout > peak_out) peak_out = (uint32_t)aout;
            }
            break;

        default:
            break;
    }

    stats.peak_in_abs = peak_in;
    stats.peak_out_abs = peak_out;
    stats.clip_count = clips;
    stats.mode = proc_mode;
}

static void handle_command(char *line)
{
    while (*line == ' ' || *line == '\t') line++;
    if (*line == 0) return;

    if (strcmp(line, "help") == 0) {
