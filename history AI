            break;

        case 1:
            // arithmetic identity
            for (uint32_t i = 0; i < HALF_WORDS; i++) {
                int32_t s = rx_buf[offset_words + i];

                int32_t ain = (s < 0) ? -s : s;
                if ((uint32_t)ain > peak_in) peak_in = (uint32_t)ain;

                int32_t y = s;

                if (y > 32767) {
                    y = 32767;
                    clips++;
                } else if (y < -32768) {
                    y = -32768;
                    clips++;
                }

                tx_buf[offset_words + i] = (int16_t)y;

                int32_t aout = (y < 0) ? -y : y;
                if ((uint32_t)aout > peak_out) peak_out = (uint32_t)aout;
            }
            break;

        case 2:
            // arithmetic half
            for (uint32_t i = 0; i < HALF_WORDS; i++) {
                int32_t s = rx_buf[offset_words + i];

                int32_t ain = (s < 0) ? -s : s;
                if ((uint32_t)ain > peak_in) peak_in = (uint32_t)ain;

                int32_t y = s >> 1;

                if (y > 32767) {
                    y = 32767;
                    clips++;
                } else if (y < -32768) {
                    y = -32768;
                    clips++;
                }

                tx_buf[offset_words + i] = (int16_t)y;

                int32_t aout = (y < 0) ? -y : y;
                if ((uint32_t)aout > peak_out) peak_out = (uint32_t)aout;
            }
            break;

        default:
            break;
    }

    stats.peak_in_abs = peak_in;
    stats.peak_out_abs = peak_out;
    stats.clip_count = clips;
    stats.mode = proc_mode;
}

static void handle_command(char *line)
{
    while (*line == ' ' || *line == '\t') line++;
    if (*line == 0) return;

    if (strcmp(line, "help") == 0) {
        print_help();
        return;
    }

    if (strcmp(line, "stat") == 0) {
