            if (rx_line_len > 0) {
                rx_line[rx_line_len] = 0;
                handle_command(rx_line);
                rx_line_len = 0;
            }
        } else if (ch == 0x08 || ch == 0x7F) {
            if (rx_line_len > 0) rx_line_len--;
        } else {
            if (rx_line_len < sizeof(rx_line) - 1) {
                rx_line[rx_line_len++] = (char)ch;
            } else {
                rx_line_len = 0;
                uart_write("ERR line too long\r\n");
            }
        }
    }
}

