        reset_stats_peaks();
        uart_write("OK mode=0 (copy)\r\n");
        return;
    }

    if (strcmp(line, "mode 1") == 0) {
        proc_mode = 1;
        stats.mode = 1;
        reset_stats_peaks();
        uart_write("OK mode=1 (identity)\r\n");
        return;
    }

    if (strcmp(line, "mode 2") == 0) {
        proc_mode = 2;
        stats.mode = 2;
        reset_stats_peaks();
        uart_write("OK mode=2 (divide by 2)\r\n");
        return;
    }

    if (strcmp(line, "mode 3") == 0) {
        proc_mode = 3;
        stats.mode = 3;
        reset_stats_peaks();
        uart_write("OK mode=3 (invert)\r\n");
        return;
    }

    if (strcmp(line, "peakclr") == 0) {
        reset_stats_peaks();
        uart_write("OK peaks cleared\r\n");
        return;
    }

    uart_write("ERR unknown command\r\n");
}

static void uart_poll_rx(void)
{
    uint8_t ch;

