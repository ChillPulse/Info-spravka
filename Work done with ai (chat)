        process_block(0, HALF_WORDS);
    }
}

void HAL_I2SEx_TxRxCpltCallback(I2S_HandleTypeDef *hi2s)
{
    if (hi2s->Instance == SPI3)
    {
        cb_full_count++;
        process_block(HALF_WORDS, HALF_WORDS);
    }
}

void HAL_I2S_ErrorCallback(I2S_HandleTypeDef *hi2s)
