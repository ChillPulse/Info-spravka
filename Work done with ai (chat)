/* =========================
 * SMALL HELPERS
 * ========================= */
static inline int16_t sat16_from_i32(int32_t x)
{
    if (x > 32767)  return 32767;
    if (x < -32768) return -32768;
    return (int16_t)x;
}

static inline uint32_t abs16_to_u32(int16_t x)
{
    if (x == -32768) return 32768u;
    return (x < 0) ? (uint32_t)(-x) : (uint32_t)x;
}

static inline float pcm16_to_f32(int16_t s)
{
    return (float)s * (1.0f / 32768.0f);
}

static inline int16_t f32_to_pcm16(float x)
{
    if (x >  0.999969f) x =  0.999969f;
    if (x < -1.000000f) x = -1.000000f;

    int32_t q = (int32_t)(x * 32767.0f);
    return sat16_from_i32(q);
}

/* =========================
 * DSP TEST CORE
 * ========================= */
static inline int16_t apply_mode_sample(int16_t s, uint32_t global_word_index, uint8_t mode)
{
    int32_t y_i32 = s;

    switch (mode)
    {
        case 0:
            /* raw copy */
            return s;

        case 1:
            /* arithmetic identity */
            return s;

        case 2:
            /* signed half via >>1 */
            y_i32 = ((int32_t)s) >> 1;
            return sat16_from_i32(y_i32);

        case 3:
            /* signed half via /2 */
            y_i32 = ((int32_t)s) / 2;
            return sat16_from_i32(y_i32);

        case 4:
            /* invert polarity */
            if (s == -32768) y_i32 = 32767;
            else             y_i32 = -((int32_t)s);
            return sat16_from_i32(y_i32);

        case 5:
            /* attenuate even words only */
            if ((global_word_index & 1u) == 0u) y_i32 = ((int32_t)s) / 2;
            else                                y_i32 = s;
            return sat16_from_i32(y_i32);

        case 6:
            /* attenuate odd words only */
            if ((global_word_index & 1u) != 0u) y_i32 = ((int32_t)s) / 2;
            else                                y_i32 = s;
            return sat16_from_i32(y_i32);

        case 7:
            /* -0.5 gain */
            y_i32 = -(((int32_t)s) / 2);
            return sat16_from_i32(y_i32);

        case 8:
            /* 0.75 gain fixed-point */
            y_i32 = (((int32_t)s) * 3) / 4;
            return sat16_from_i32(y_i32);

        case 9:
        {
            /* float bypass unity */
            float x = pcm16_to_f32(s);
            float y = x;
            return f32_to_pcm16(y);
        }

        case 10:
        {
            /* float gain 0.5 */
            float x = pcm16_to_f32(s);
            float y = x * 0.5f;
            return f32_to_pcm16(y);
        }

        default:
            return s;
    }
}

static void zero_tx_block(uint32_t start_word, uint32_t count_words)
{
    memset((void *)&tx_buf[start_word], 0, count_words * sizeof(int16_t));
}

static void zero_audio_buffers(void)
{
    memset((void *)rx_buf, 0, sizeof(rx_buf));
    memset((void *)tx_buf, 0, sizeof(tx_buf));
}

static void process_block(uint32_t start_word, uint32_t count_words)
{
    uint8_t mode = g_test_mode;
    uint8_t force_mute_now = g_force_mute;
    uint8_t rearm_busy_now = g_rearm_busy;

    if (rearm_busy_now || force_mute_now)
    {
        zero_tx_block(start_word, count_words);
        return;
    }

    if (g_warmup_halves_left > 0)
    {
        zero_tx_block(start_word, count_words);
        g_warmup_halves_left--;
        return;
    }

    for (uint32_t i = 0; i < count_words; i++)
    {
        uint32_t gi = start_word + i;
        int16_t s = rx_buf[gi];
        int16_t y = apply_mode_sample(s, gi, mode);

        tx_buf[gi] = y;

        uint32_t arx = abs16_to_u32(s);
        uint32_t atx = abs16_to_u32(y);

        if (arx > g_rx_peak) g_rx_peak = arx;
        if (atx > g_tx_peak) g_tx_peak = atx;
    }
}

/* =========================
 * SOURCE MUTE MONITOR
 * ========================= */
static void poll_source_mute(void)
{
    uint8_t pin = (HAL_GPIO_ReadPin(SRC_MUTE_PORT, SRC_MUTE_PIN) == GPIO_PIN_SET) ? 1u : 0u;
    g_last_ws_state = (HAL_GPIO_ReadPin(WS_SENSE_PORT, WS_SENSE_PIN) == GPIO_PIN_SET) ? 1u : 0u;

    if (pin != g_src_pin_state)
    {
        g_src_pin_state = pin;
        g_src_edge_count++;

        if (pin)
            uart_log("SRC_MUTE = 1\r\n");
        else
            uart_log("SRC_MUTE = 0\r\n");
    }
}

/* =========================
 * MANUAL RESYNC
 * ========================= */
static uint8_t wait_for_ws_phase_low(uint32_t timeout_ms)
{
    uint32_t t0 = HAL_GetTick();

    /* wait until WS goes HIGH at least once */
    while (HAL_GPIO_ReadPin(WS_SENSE_PORT, WS_SENSE_PIN) != GPIO_PIN_SET)
    {
        if ((HAL_GetTick() - t0) > timeout_ms)
            return 0;
    }

    /* then wait for next LOW */
    while (HAL_GPIO_ReadPin(WS_SENSE_PORT, WS_SENSE_PIN) != GPIO_PIN_RESET)
    {
        if ((HAL_GetTick() - t0) > timeout_ms)
            return 0;
    }

    return 1;
}

static uint8_t manual_resync(void)
{
    HAL_StatusTypeDef st;

    g_rearm_count++;
    g_rearm_busy = 1;

    uart_log("\r\nRESYNC: begin\r\n");

    /* make output silent immediately */
    zero_tx_block(0, DMA_WORDS);

    /* stop ongoing DMA transfer */
    st = HAL_I2S_DMAStop(&hi2s3);
    if (st != HAL_OK)
    {
        uart_log("RESYNC: HAL_I2S_DMAStop != OK\r\n");
    }

    /* fully re-init peripheral */
    st = HAL_I2S_DeInit(&hi2s3);
    if (st != HAL_OK)
    {
        uart_log("RESYNC: HAL_I2S_DeInit != OK\r\n");
    }

    zero_audio_buffers();

    /* re-configure SPI3/I2S3 */
    MX_I2S3_Init();

    /* best-effort wait for WS phase */
    if (!wait_for_ws_phase_low(WS_WAIT_TIMEOUT_MS))
    {
        uart_log("RESYNC: WS wait timeout\r\n");
        g_rearm_fail++;
        g_rearm_busy = 0;
        return 0;
    }

    /* start DMA again */
    st = HAL_I2SEx_TransmitReceive_DMA(&hi2s3,
                                       (uint16_t *)tx_buf,
                                       (uint16_t *)rx_buf,
                                       DMA_WORDS);
    if (st != HAL_OK)
    {
        uart_log("RESYNC: DMA start FAIL\r\n");
        g_rearm_fail++;
        g_rearm_busy = 0;
        return 0;
    }

    g_warmup_halves_left = g_warmup_halves_cfg;
    g_rearm_ok++;
    g_rearm_busy = 0;

    uart_log("RESYNC: OK, warmup_half=%lu, ws=%u\r\n",
             g_warmup_halves_cfg,
             (uint32_t)((HAL_GPIO_ReadPin(WS_SENSE_PORT, WS_SENSE_PIN) == GPIO_PIN_SET) ? 1u : 0u));

    return 1;
}

static void cycle_warmup_cfg(void)
{
    if (g_warmup_halves_cfg == 0)       g_warmup_halves_cfg = 4;
    else if (g_warmup_halves_cfg == 4)  g_warmup_halves_cfg = 8;
    else if (g_warmup_halves_cfg == 8)  g_warmup_halves_cfg = 16;
    else if (g_warmup_halves_cfg == 16) g_warmup_halves_cfg = 32;
    else                                g_warmup_halves_cfg = 0;

    uart_log("\r\nWarmup half-blocks = %lu\r\n", g_warmup_halves_cfg);
}

