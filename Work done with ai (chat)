# Как должен выглядеть этот canonical layer

Для твоего проекта я бы сделал так:

## Вариант 1 — сначала через `int16_t`
Минимальный и безопасный этап.

```c
static inline float pcm16_to_f32(uint16_t w)
{
    int16_t s = (int16_t)w;
    return (float)s * (1.0f / 32768.0f);
}

static inline uint16_t f32_to_pcm16(float x)
{
    if (x >  0.999969f) x =  0.999969f;
    if (x < -1.000000f) x = -1.000000f;

    int32_t q = (int32_t)(x * 32767.0f);
    if (q >  32767) q =  32767;
    if (q < -32768) q = -32768;

    return (uint16_t)(int16_t)q;
}
```

И дальше уже:

```c
for (size_t i = 0; i < n_words; i += 2) {
    float L = pcm16_to_f32(rx[i]);
    float R = pcm16_to_f32(rx[i + 1]);

    // DSP тут
    // L, R = process(L, R)

    tx[i]     = f32_to_pcm16(L);
    tx[i + 1] = f32_to_pcm16(R);
}
```

