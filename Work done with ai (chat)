## 3) Если у тебя ещё нет `printf` в UART — добавь это

```c
/* USER CODE BEGIN 0 */

static void uart_log(const char *fmt, ...)
{
    char buf[160];
    va_list ap;
    va_start(ap, fmt);
    int len = vsnprintf(buf, sizeof(buf), fmt, ap);
    va_end(ap);

    if (len < 0) return;
    if (len > (int)sizeof(buf)) len = sizeof(buf);

    HAL_UART_Transmit(&huart2, (uint8_t *)buf, len, 100);
}

int _write(int file, char *ptr, int len)
{
    HAL_UART_Transmit(&huart2, (uint8_t*)ptr, len, 100);
    return len;
}

static inline int16_t sat16_from_i32(int32_t x)
{
    if (x > 32767)  return 32767;
    if (x < -32768) return -32768;
    return (int16_t)x;
}

static inline int16_t apply_mode_sample(int16_t s, uint32_t global_word_index)
{
    int32_t y = s;

    switch (TEST_MODE)
    {
        case 0:
            // raw copy
            y = s;
            break;

        case 1:
            // arithmetic identity
            y = s;
            break;

        case 2:
            // signed half via >>1
            // диагностический режим: если он грязный, а mode 3 чистый,
            // значит проблема именно в shift-варианте
            y = ((int32_t)s) >> 1;
            break;

        case 3:
            // safe signed half via /2
            y = ((int32_t)s) / 2;
            break;

        case 4:
            // invert
            // отдельно обрабатываем -32768
            if (s == -32768) y = 32767;
            else             y = -((int32_t)s);
            break;

        case 5:
            // attenuate even words only
            // если поток обычный interleaved L,R,L,R...
            // то это скорее всего один канал
            if ((global_word_index & 1u) == 0u) y = ((int32_t)s) / 2;
            else                                y = s;
            break;

        case 6:
            // attenuate odd words only
            if ((global_word_index & 1u) != 0u) y = ((int32_t)s) / 2;
            else                                y = s;
            break;

        default:
            y = s;
            break;
    }

    return sat16_from_i32(y);
}

static void process_block(uint32_t start_word, uint32_t count_words)
{
    for (uint32_t i = 0; i < count_words; i++)
    {
        uint32_t gi = start_word + i;
        int16_t s = rx_buf[gi];
        int16_t y = apply_mode_sample(s, gi);
        tx_buf[gi] = y;
    }
}

/* USER CODE END 0 */
```

