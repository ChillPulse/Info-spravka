#define DMA_FRAMES       128   // stereo frames in full buffer
#define DMA_WORDS        (DMA_FRAMES * 2)   // interleaved L/R int16_t words
#define HALF_WORDS       (DMA_WORDS / 2)

static int16_t rx_buf[DMA_WORDS];
static int16_t tx_buf[DMA_WORDS];

volatile uint32_t cb_half_count = 0;
volatile uint32_t cb_full_count = 0;
