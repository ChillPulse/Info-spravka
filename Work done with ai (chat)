```c
#include "stm32f4xx_hal.h"
#include <string.h>
#include <stdio.h>
#include <stdarg.h>
#include <stdint.h>

/* =========================
 * AUDIO BUFFER CONFIG
 * ========================= */
#define DMA_FRAMES       128
#define DMA_WORDS        (DMA_FRAMES * 2)   // int16 words: L,R,L,R...
#define HALF_WORDS       (DMA_WORDS / 2)

/* =========================
 * GLOBAL HANDLES
 * ========================= */
I2S_HandleTypeDef hi2s3;
UART_HandleTypeDef huart2;

DMA_HandleTypeDef hdma_i2s3_ext_rx;
DMA_HandleTypeDef hdma_spi3_tx;

/* =========================
 * AUDIO BUFFERS
 * ========================= */
static int16_t rx_buf[DMA_WORDS] __attribute__((aligned(4)));
static int16_t tx_buf[DMA_WORDS] __attribute__((aligned(4)));

/* =========================
 * STATUS / CONTROL
 * ========================= */
volatile uint32_t cb_half_count = 0;
volatile uint32_t cb_full_count = 0;
volatile uint32_t i2s_err_count = 0;
volatile uint8_t  g_test_mode = 0;

/* =========================
 * PROTOTYPES
 * ========================= */
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
static void MX_I2S3_Init(void);

static void uart_log(const char *fmt, ...);
static void print_help(void);
static void print_status(void);
static void handle_uart_commands(void);

static inline int16_t sat16_from_i32(int32_t x);
static inline int16_t apply_mode_sample(int16_t s, uint32_t global_word_index, uint8_t mode);
static void process_block(uint32_t start_word, uint32_t count_words);

void Error_Handler(void);

/* =========================
 * MAIN
 * ========================= */
int main(void)
{
    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_USART2_UART_Init();
    MX_I2S3_Init();

    memset((void *)rx_buf, 0, sizeof(rx_buf));
    memset((void *)tx_buf, 0, sizeof(tx_buf));

    uart_log("\r\n=== OMNIA-V I2S UART MODE TEST ===\r\n");
    uart_log("DMA_FRAMES = %u\r\n", DMA_FRAMES);
    uart_log("DMA_WORDS  = %u\r\n", DMA_WORDS);
    uart_log("Initial mode = %u\r\n", g_test_mode);
    print_help();

    if (HAL_I2SEx_TransmitReceive_DMA(&hi2s3,
                                      (uint16_t *)tx_buf,
                                      (uint16_t *)rx_buf,
                                      DMA_WORDS) != HAL_OK)
    {
        uart_log("HAL_I2SEx_TransmitReceive_DMA() FAILED\r\n");
        Error_Handler();
    }

    uart_log("I2S DMA START OK\r\n");

    uint32_t last_log = HAL_GetTick();

    while (1)
    {
        handle_uart_commands();

        if ((HAL_GetTick() - last_log) >= 1000U)
        {
            last_log = HAL_GetTick();
            print_status();
        }
    }
}

/* =========================
 * DSP TEST CORE
 * ========================= */
static inline int16_t sat16_from_i32(int32_t x)
{
    if (x > 32767)  return 32767;
    if (x < -32768) return -32768;
    return (int16_t)x;
}

static inline int16_t apply_mode_sample(int16_t s, uint32_t global_word_index, uint8_t mode)
{
    int32_t y = s;

    switch (mode)
    {
        case 0:
            /* raw copy */
            y = s;
            break;

        case 1:
            /* arithmetic identity */
            y = s;
            break;

        case 2:
            /* signed half via >>1 */
            y = ((int32_t)s) >> 1;
            break;

        case 3:
            /* signed half via /2 */
            y = ((int32_t)s) / 2;
            break;

        case 4:
            /* invert polarity */
            if (s == -32768) y = 32767;
            else             y = -((int32_t)s);
            break;

        case 5:
            /* attenuate even words only */
            if ((global_word_index & 1u) == 0u) y = ((int32_t)s) / 2;
            else                                y = s;
            break;

        case 6:
            /* attenuate odd words only */
            if ((global_word_index & 1u) != 0u) y = ((int32_t)s) / 2;
            else                                y = s;
            break;

        default:
            y = s;
            break;
    }

    return sat16_from_i32(y);
}

static void process_block(uint32_t start_word, uint32_t count_words)
{
    uint8_t mode = g_test_mode;

    for (uint32_t i = 0; i < count_words; i++)
    {
        uint32_t gi = start_word + i;
        int16_t s = rx_buf[gi];
        int16_t y = apply_mode_sample(s, gi, mode);
        tx_buf[gi] = y;
    }
}

/* =========================
 * HAL CALLBACKS
 * ========================= */
void HAL_I2SEx_TxRxHalfCpltCallback(I2S_HandleTypeDef *hi2s)
{
    if (hi2s->Instance == SPI3)
    {
        cb_half_count++;
        process_block(0, HALF_WORDS);
    }
}

void HAL_I2SEx_TxRxCpltCallback(I2S_HandleTypeDef *hi2s)
{
    if (hi2s->Instance == SPI3)
    {
        cb_full_count++;
        process_block(HALF_WORDS, HALF_WORDS);
    }
}

void HAL_I2S_ErrorCallback(I2S_HandleTypeDef *hi2s)
{
    if (hi2s->Instance == SPI3)
    {
        i2s_err_count++;
    }
}

/* =========================
 * UART
 * ========================= */
static void uart_log(const char *fmt, ...)
{
    char buf[192];
    va_list ap;
    va_start(ap, fmt);
    int len = vsnprintf(buf, sizeof(buf), fmt, ap);
    va_end(ap);

    if (len <= 0) return;
    if (len > (int)sizeof(buf)) len = sizeof(buf);

    HAL_UART_Transmit(&huart2, (uint8_t *)buf, (uint16_t)len, 100);
}

int _write(int file, char *ptr, int len)
{
    (void)file;
    HAL_UART_Transmit(&huart2, (uint8_t *)ptr, (uint16_t)len, 100);
    return len;
}

static const char *mode_name(uint8_t mode)
{
    switch (mode)
    {
        case 0: return "raw copy";
        case 1: return "arithmetic identity";
        case 2: return "signed shift half (>>1)";
        case 3: return "signed divide half (/2)";
        case 4: return "invert polarity";
        case 5: return "attenuate even words only";
        case 6: return "attenuate odd words only";
        default: return "unknown";
    }
}

static void print_help(void)
{
    uart_log("Commands:\r\n");
    uart_log("  0..6 : set test mode\r\n");
    uart_log("  s    : status\r\n");
    uart_log("  r    : reset counters\r\n");
    uart_log("  h    : help\r\n");
    uart_log("\r\n");
    uart_log("Modes:\r\n");
    uart_log("  0 = raw copy\r\n");
    uart_log("  1 = arithmetic identity\r\n");
    uart_log("  2 = signed >>1\r\n");
    uart_log("  3 = signed /2\r\n");
    uart_log("  4 = invert polarity\r\n");
    uart_log("  5 = attenuate even words only\r\n");
    uart_log("  6 = attenuate odd words only\r\n");
    uart_log("\r\n");
}

static void print_status(void)
{
    uart_log("status: mode=%u (%s), half=%lu, full=%lu, i2s_err=%lu\r\n",
             g_test_mode,
             mode_name(g_test_mode),
             cb_half_count,
             cb_full_count,
             i2s_err_count);
}

static void handle_uart_commands(void)
{
    uint8_t ch;

    if (HAL_UART_Receive(&huart2, &ch, 1, 0) != HAL_OK)
        return;

    if (ch >= '0' && ch <= '6')
    {
        g_test_mode = (uint8_t)(ch - '0');
        uart_log("\r\nSET MODE = %u (%s)\r\n", g_test_mode, mode_name(g_test_mode));
        return;
    }

    switch (ch)
    {
        case 's':
        case 'S':
            uart_log("\r\n");
            print_status();
            break;

        case 'r':
        case 'R':
            cb_half_count = 0;
            cb_full_count = 0;
            i2s_err_count = 0;
            uart_log("\r\nCounters reset\r\n");
            print_status();
            break;

        case 'h':
        case 'H':
            uart_log("\r\n");
            print_help();
            break;

        case '\r':
        case '\n':
            break;

        default:
            uart_log("\r\nUnknown cmd: '%c'\r\n", ch);
            print_help();
            break;
    }
}

