/* =========================
 * SMALL HELPERS
 * ========================= */
static inline int16_t sat16_from_i32(int32_t x)
{
    if (x > 32767)  return 32767;
    if (x < -32768) return -32768;
    return (int16_t)x;
}

static inline uint32_t abs16_to_u32(int16_t x)
{
    if (x == -32768) return 32768u;
    return (x < 0) ? (uint32_t)(-x) : (uint32_t)x;
}

static inline float pcm16_to_f32(int16_t s)
{
    return (float)s * (1.0f / 32768.0f);
}

static inline int16_t f32_to_pcm16(float x)
{
    if (x >  0.999969f) x =  0.999969f;
    if (x < -1.000000f) x = -1.000000f;

    int32_t q = (int32_t)(x * 32767.0f);
    return sat16_from_i32(q);
}

/* =========================
 * DSP TEST CORE
 * ========================= */
static inline int16_t apply_mode_sample(int16_t s, uint32_t global_word_index, uint8_t mode)
{
    int32_t y_i32 = s;

    switch (mode)
    {
        case 0:
            /* raw copy */
            y_i32 = s;
            return (int16_t)y_i32;

        case 1:
            /* arithmetic identity */
            y_i32 = s;
            return (int16_t)y_i32;

        case 2:
            /* signed half via >>1 */
            y_i32 = ((int32_t)s) >> 1;
            return sat16_from_i32(y_i32);

        case 3:
            /* signed half via /2 */
            y_i32 = ((int32_t)s) / 2;
            return sat16_from_i32(y_i32);

        case 4:
            /* invert polarity */
            if (s == -32768) y_i32 = 32767;
            else             y_i32 = -((int32_t)s);
            return sat16_from_i32(y_i32);

        case 5:
            /* attenuate even words only */
            if ((global_word_index & 1u) == 0u) y_i32 = ((int32_t)s) / 2;
            else                                y_i32 = s;
            return sat16_from_i32(y_i32);

        case 6:
            /* attenuate odd words only */
            if ((global_word_index & 1u) != 0u) y_i32 = ((int32_t)s) / 2;
            else                                y_i32 = s;
            return sat16_from_i32(y_i32);

        case 7:
            /* -0.5 gain */
            y_i32 = -(((int32_t)s) / 2);
            return sat16_from_i32(y_i32);

        case 8:
            /* 0.75 gain fixed-point */
            y_i32 = (((int32_t)s) * 3) / 4;
            return sat16_from_i32(y_i32);

        case 9:
        {
            /* float bypass unity */
            float x = pcm16_to_f32(s);
            float y = x;
            return f32_to_pcm16(y);
        }

        case 10:
        {
            /* float gain 0.5 */
            float x = pcm16_to_f32(s);
            float y = x * 0.5f;
            return f32_to_pcm16(y);
        }

        default:
            return s;
    }
}

static void process_block(uint32_t start_word, uint32_t count_words)
{
    uint8_t mode = g_test_mode;
    uint8_t gate_now = g_gate_active;
    uint8_t force_mute_now = g_force_mute;

    for (uint32_t i = 0; i < count_words; i++)
    {
        uint32_t gi = start_word + i;
        int16_t s = rx_buf[gi];
        int16_t y;

        uint32_t arx = abs16_to_u32(s);
        if (arx > g_rx_peak) g_rx_peak = arx;

        if (force_mute_now || gate_now)
        {
            y = 0;
        }
        else
        {
            y = apply_mode_sample(s, gi, mode);
        }

        tx_buf[gi] = y;

        uint32_t atx = abs16_to_u32(y);
        if (atx > g_tx_peak) g_tx_peak = atx;
    }
}

/* =========================
 * SOURCE MUTE POLL
 * ========================= */
static void poll_source_mute(void)
{
    uint32_t now = HAL_GetTick();
    uint8_t pin = (HAL_GPIO_ReadPin(SRC_MUTE_PORT, SRC_MUTE_PIN) == GPIO_PIN_SET) ? 1u : 0u;

    if (pin != g_src_pin_state)
    {
        g_src_pin_state = pin;
        g_src_edge_count++;

        if (pin)
        {
            uart_log("SRC_MUTE = 1\r\n");
        }
        else
        {
            g_hold_until_ms = now + g_post_mute_hold_ms;
            uart_log("SRC_MUTE = 0, hold %lu ms\r\n", g_post_mute_hold_ms);
        }
    }

    if (!g_gate_enable)
    {
        g_gate_active = 0;
    }
    else
    {
        if (pin)
        {
            g_gate_active = 1;
        }
        else
        {
            if ((int32_t)(g_hold_until_ms - now) > 0)
                g_gate_active = 1;
            else
                g_gate_active = 0;
        }
    }
}

