static inline int16_t sat16_from_i32(int32_t x)
{
    if (x > 32767)  return 32767;
    if (x < -32768) return -32768;
    return (int16_t)x;
}

static inline int16_t apply_mode_sample(int16_t s, uint32_t global_word_index, uint8_t mode)
{
    int32_t y = s;

    switch (mode)
    {
        case 0:
            /* raw copy */
            y = s;
            break;

        case 1:
            /* arithmetic identity */
            y = s;
            break;

        case 2:
            /* signed half via >>1 */
            y = ((int32_t)s) >> 1;
            break;

        case 3:
            /* signed half via /2 */
            y = ((int32_t)s) / 2;
            break;

        case 4:
            /* invert polarity */
            if (s == -32768) y = 32767;
            else             y = -((int32_t)s);
            break;

        case 5:
            /* attenuate even words only */
            if ((global_word_index & 1u) == 0u) y = ((int32_t)s) / 2;
            else                                y = s;
            break;

        case 6:
            /* attenuate odd words only */
            if ((global_word_index & 1u) != 0u) y = ((int32_t)s) / 2;
            else                                y = s;
            break;

        default:
            y = s;
            break;
    }

    return sat16_from_i32(y);
}

static void process_block(uint32_t start_word, uint32_t count_words)
{
    uint8_t mode = g_test_mode;

    for (uint32_t i = 0; i < count_words; i++)
    {
        uint32_t gi = start_word + i;
        int16_t s = rx_buf[gi];
        int16_t y = apply_mode_sample(s, gi, mode);
        tx_buf[gi] = y;
    }
}

