    if (g_post_fall_hold_ms == 0)         g_post_fall_hold_ms = 50;
    else if (g_post_fall_hold_ms == 50)   g_post_fall_hold_ms = 100;
    else if (g_post_fall_hold_ms == 100)  g_post_fall_hold_ms = 200;
