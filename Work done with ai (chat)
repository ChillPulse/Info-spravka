static void handle_uart_commands(void)
{
    uint8_t ch;

    if (HAL_UART_Receive(&huart2, &ch, 1, 0) != HAL_OK)
        return;

    if (ch >= '0' && ch <= '9')
    {
        g_test_mode = (uint8_t)(ch - '0');
        reset_runtime_counters();
        uart_log("\r\nSET MODE = %u (%s)\r\n", g_test_mode, mode_name(g_test_mode));
        return;
    }

    switch (ch)
    {
        case 'a':
        case 'A':
            g_test_mode = 10;
            reset_runtime_counters();
            uart_log("\r\nSET MODE = %u (%s)\r\n", g_test_mode, mode_name(g_test_mode));
            break;

        case 'g':
        case 'G':
            g_gate_enable = g_gate_enable ? 0u : 1u;
            uart_log("\r\nSOURCE GATE = %s\r\n", g_gate_enable ? "ON" : "OFF");
            break;

        case 'm':
        case 'M':
            g_force_mute = g_force_mute ? 0u : 1u;
            uart_log("\r\nFORCE_MUTE = %s\r\n", g_force_mute ? "ON" : "OFF");
            break;

        case 'H':
            if (g_post_mute_hold_ms == 200)
                g_post_mute_hold_ms = 2000;
            else
                g_post_mute_hold_ms = 200;
            uart_log("\r\nPOST_MUTE_HOLD = %lu ms\r\n", g_post_mute_hold_ms);
            break;

        case 's':
        case 'S':
            uart_log("\r\n");
            print_status();
            break;

        case 'r':
        case 'R':
            reset_runtime_counters();
            uart_log("\r\nCounters/peaks reset\r\n");
            print_status();
            break;

        case 'h':
            uart_log("\r\n");
            print_help();
            break;

        case '\r':
        case '\n':
            break;

        default:
            uart_log("\r\nUnknown cmd: '%c'\r\n", ch);
            print_help();
            break;
    }
}

